# ============================================================================
# FC IG Lead Discovery — Environment Variables
# Copy to .env and fill in. Never commit .env.
#
# All required values must be set. Values shown as `<TYPE>` are placeholders —
# replace them. Values with `=default` are optional overrides.
# ============================================================================


# ─── Supabase ───────────────────────────────────────────────────────────────
# From: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...


# ─── Anthropic (Claude) ─────────────────────────────────────────────────────
# From: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Model strings. Defaults shown — only override if you know why.
CLAUDE_MODEL_OPENER=claude-sonnet-4-6
CLAUDE_MODEL_AGENT=claude-sonnet-4-6
CLAUDE_MODEL_QUALIFIER=claude-haiku-4-5-20251001


# ─── Encryption (for storing IG session cookies in Supabase) ────────────────
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# This key MUST be stable across restarts. Losing it means losing all stored
# burner sessions and re-capturing every cookie.
FERNET_KEY=


# ─── Discord (HiTL queue, handoffs, operator-mode cards) ────────────────────
# Bot token from: https://discord.com/developers/applications → your app → Bot
DISCORD_BOT_TOKEN=

# Server ID. Enable Developer Mode in Discord, right-click your server → Copy
# Server ID. REQUIRED for instant slash-command propagation; without it,
# new commands take up to 1 hour to appear in autocomplete.
DISCORD_GUILD_ID=

# Channel IDs. Right-click each channel → Copy Channel ID.
# WARMING_QUEUE and HANDOFF can point to the same channel for V1; the bot
# falls back to HANDOFF if WARMING_QUEUE is empty.
DISCORD_WARMING_QUEUE_CHANNEL_ID=
DISCORD_HANDOFF_CHANNEL_ID=
DISCORD_ALERTS_CHANNEL_ID=
DISCORD_METRICS_CHANNEL_ID=


# ─── Proxy (residential / mobile) ───────────────────────────────────────────
# Fallback defaults — set these if you want every ig_account that doesn't
# carry its own proxy_endpoint JSON to share a default proxy.
# In production each burner SHOULD have its own proxy in the ig_accounts row.
DEFAULT_PROXY_USER=
DEFAULT_PROXY_PASS=
DEFAULT_PROXY_HOST=
DEFAULT_PROXY_PORT=


# ─── Operational ────────────────────────────────────────────────────────────
ENVIRONMENT=production       # production | staging | dev
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
TIMEZONE=Asia/Manila

# Rate-limit safety multiplier applied on top of every IG daily cap.
# 1.0 = use full caps (risky). 0.5 = use half. 0.2 = ultra-safe for new burners.
# Strongly recommend 0.2–0.3 for the first 2 weeks of a new burner.
RATE_LIMIT_SAFETY_FACTOR=0.2


# ─── Test Mode (for $0 / burner-validation runs) ────────────────────────────
# When TEST_MODE=true, M1/M2 discovery hard-stops after TEST_MODE_PROFILE_LIMIT
# accounts have been added to `accounts`. Useful while shaking down a new
# burner so you don't burn its daily budget.
# Set to false (or remove) once you've validated and are ready to scale.
TEST_MODE=true
TEST_MODE_PROFILE_LIMIT=10


# ─── LLM Mode ───────────────────────────────────────────────────────────────
# 'api'          → call Anthropic API directly (costs money per generation)
# 'manual_paste' → write prompts to a Supabase queue table; you paste them
#                  into Claude.ai by hand (free with Claude Max subscription)
LLM_MODE=api


# ─── IG session storage paths (Playwright cookies + screenshots) ────────────
# Directory inside the container where encrypted-at-rest cookies are cached,
# and where send-failure debug screenshots get dumped.
# Defaults are fine if you're using the docker-compose volume.
IG_SESSION_DIR=/app/ig_sessions
IG_DEBUG_DIR=/app/ig_sessions/_debug


# ─── M6 sender safety guard ─────────────────────────────────────────────────
# Hard ceiling on prospect follower_count above which the sender refuses to
# DM (avoids accidentally cold-DMing celebrities who'll report you).
# 500k is a reasonable floor for most niches.
OPENER_SEND_MAX_FOLLOWER_COUNT=500000


# ─── Scheduler intervals (minutes) ──────────────────────────────────────────
# How often the background cron loops run. Defaults below are safe for a
# single-burner setup. Raise them for lower DB chatter; lower them only
# if you understand the downstream load.
SCHEDULER_GHOST_FOLLOWUPS_MINUTES=5
SCHEDULER_COOLDOWN_REAPER_MINUTES=5


# ─── Cross-platform research (M3) ───────────────────────────────────────────
# YouTube Data API v3 key (free tier — 10,000 units/day, plenty for solo use).
# From: https://console.cloud.google.com/apis/credentials
# TikTok scraping uses the public web frontend; no key needed.
YOUTUBE_API_KEY=
